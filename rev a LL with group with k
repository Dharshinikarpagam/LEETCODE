/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* rev(ListNode* head)
    {
        if(head==NULL || head->next==NULL)
        {
            return head;
        }
        ListNode* newnode=rev(head->next);
        ListNode* front=head->next;
        front->next=head;
        return newnode;
    }
    ListNode* findnode(ListNode* temp,int k)
    {
        k-=1;
        while(temp!=NULL && k>0)
        {
            k--;
            temp=temp->next;
        }
        return temp;
    }
    ListNode* reverseKGroup(ListNode* head, int k) {
        ListNode* temp=head;
        ListNode* prev=NULL;
        while(temp!=NULL)
        {
            ListNode* knode=findnode(temp,k);
            if(knode==NULL)
            {
                if(prev)
                {
                    prev->next=temp;
                }
                break;
            }
            ListNode* nxtnode=knode->next;
            knode->next=NULL;
            rev(temp);
            if(temp==head)
            {
                head=knode;
            }
            else
            {
                prev->next=knode;
            }
            prev=temp;
            temp=nxtnode;
        }
        return head;
    }
};
