class Solution {
public:
    long long beautifulSubarrays(vector<int>& nums,int k) {
        int n=nums.size();
        long long xr=0;
        map<long long,long long> mpp;
        mpp[xr]++;
        long long cnt=0;
        for(int i=0;i<n;i++)
        {
            xr=xr^nums[i];
            long long x=xr^k;
            cnt+=mpp[x];
            mpp[xr]++;

        }
        return cnt;
    }
};
