class Solution {
public:
    int check(TreeNode* node)
    {
        if(node==NULL)
            return 0;
        int lh=check(node->left);
        int rh=check(node->right);
        if(lh==-1 || rh==-1)
            return -1;
        if(abs(lh-rh)>1) return -1;
        return max(lh,rh)+1;
    }
    bool isBalanced(TreeNode* root) {
        return check(root)!=-1;
    }
};
