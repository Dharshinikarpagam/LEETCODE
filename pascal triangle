## pascal triangle (I) print the row 
class Solution {
public:
    vector<int> getRow(int rowIndex) {
        long long val=1;
        vector<int> ansrow;
        ansrow.push_back(1);
        for(int c=1;c<=rowIndex;c++)
        {
            val=val*(rowIndex-c+1);
            val=val/c;
            ansrow.push_back(val);
        }
    return ansrow;
    }
};

## Pascal triangle (II) print the triangle 
class Solution {
public:
    vector<vector<int>> generate(int numRows) {
        vector<vector<int>> ans ;
        for(int i=1;i<=numRows;i++)
        {
            long long val=1;
            vector<int> ansRow;
            ansRow.push_back(1);
            for(int c=1;c<i;c++)
            {
               val=val*(i-c);
               val=val/c;
                ansRow.push_back(val);
             }
        ans.push_back(ansRow);
        }

    return ans; 
    }  
};
