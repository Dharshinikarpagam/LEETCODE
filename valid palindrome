class Solution {
public:
    bool func(int i,string &s)
    {
        int n=s.size();
        if(i>=n/2)
        {
            return true;
        }
        if(s[i]!=s[n-i-1])
        {
            return false;
        }
        return func(i+1,s);
    }
    bool isPalindrome(string s) {
        string temp="";
        for(char ch:s)
        {
            if(isalnum(ch))
            {
                temp+=tolower(ch);
            }
        }
        return func(0,temp);
    }
};
